{
  "route": {
    "rule_set": [
      {
        "tag": "geosite",
        "type": "local",
        "format": "binary",
        "path": "/etc/XMBox/geosite.db"
      },
      {
        "tag": "geoip",
        "type": "local",
        "format": "binary",
        "path": "/etc/XMBox/geoip.db"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    }
  }
}